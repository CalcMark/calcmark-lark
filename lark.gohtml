<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CalcMark Document</title>
<style>
{{.Style}}
:root {
  --cm-accent: #7D56F4;
  --cm-accent-light: #7D56F4;
  --cm-font-sans: "Inter", system-ui, -apple-system, sans-serif;
  --cm-font-mono: "JetBrains Mono", "Fira Code", ui-monospace, "SF Mono", Monaco, Consolas, monospace;
}
@media (prefers-color-scheme: dark) {
  :root:not([data-theme="light"]) {
    --cm-accent: #a371f7;
    --cm-accent-light: #a371f7;
    --cm-text: #e5e5e5;
    --cm-text-secondary: #8b949e;
    --cm-text-muted: #8b949e;
    --cm-text-code: #e5e5e5;
    --cm-bg: #0d1117;
    --cm-bg-subtle: #161b22;
    --cm-bg-frontmatter: #1c2128;
    --cm-border: #30363d;
    --cm-error: #f85149;
    --cm-error-bg: #3d1417;
    --cm-warning: #d4a017;
    --cm-warning-bg: #2d2a1e;
    --cm-warning-border: #d4a017;
    --cm-cascading: #d4a017;
  }
}
[data-theme="dark"] {
  --cm-accent: #a371f7;
  --cm-accent-light: #a371f7;
  --cm-text: #e5e5e5;
  --cm-text-secondary: #8b949e;
  --cm-text-muted: #8b949e;
  --cm-text-code: #e5e5e5;
  --cm-bg: #0d1117;
  --cm-bg-subtle: #161b22;
  --cm-bg-frontmatter: #1c2128;
  --cm-border: #30363d;
  --cm-error: #f85149;
  --cm-error-bg: #3d1417;
  --cm-warning: #d4a017;
  --cm-warning-bg: #2d2a1e;
  --cm-warning-border: #d4a017;
  --cm-cascading: #d4a017;
}
body {
  background: var(--cm-bg, #ffffff);
}
/* Embedded mode: goldmark-rendered HTML content */
.embedded-content p { margin: 0.75em 0; }
.embedded-content h1, .embedded-content h2, .embedded-content h3,
.embedded-content h4, .embedded-content h5, .embedded-content h6 { margin-top: 1.5em; margin-bottom: 0.5em; }
.embedded-content code { background: var(--cm-bg-subtle); padding: 0.2em 0.4em; border-radius: 3px; font-family: var(--cm-font-mono); font-size: 0.9em; }
.embedded-content pre:has(code.language-calcmark),
.embedded-content pre:has(code.language-cm) { background: var(--cm-bg-subtle); border-left: 4px solid var(--cm-accent); padding: 1em; border-radius: 4px; overflow-x: auto; }
.embedded-content code.language-calcmark,
.embedded-content code.language-cm { color: var(--cm-text-code); font-weight: 400; }
.embedded-content pre { background: var(--cm-bg-subtle); padding: 1em; border-radius: 6px; overflow-x: auto; }
.embedded-content pre code { background: none; padding: 0; }
.embedded-content blockquote { border-left: 3px solid var(--cm-accent); padding-left: 1em; margin: 1em 0; color: var(--cm-text-secondary); }
.embedded-content blockquote p { margin: 0.5em 0; }
.embedded-content table { border-collapse: collapse; width: 100%; margin: 1em 0; }
.embedded-content th, .embedded-content td { border: 1px solid var(--cm-border); padding: 0.5em 0.75em; text-align: left; }
.embedded-content th { background: var(--cm-bg-subtle); font-weight: 600; }
.embedded-content img { max-width: 100%; height: auto; }
.embedded-content hr { border: none; border-top: 1px solid var(--cm-border); margin: 2em 0; }
</style>
</head>
<body>
{{if .Content}}
<div class="embedded-content">{{.Content}}</div>
{{else}}
{{template "cm-content" .}}
{{end}}
</body>
</html>
